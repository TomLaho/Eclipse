# Eclipse secrets. Copy to .env (git-ignored) and fill in.
# Everything here is optional — Eclipse runs fully local without any of it.
# Each integration degrades silently when its keys are absent.

# --- Telegram (Phase 2): per-meeting summaries + interactive approval ---
# 1. Talk to @BotFather, /newbot, copy the token.
# 2. Message your new bot, then visit
#    https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Notion (Phase 3): push approved todos to a database ---
# Create an internal integration at https://www.notion.so/my-integrations
# and share the target page with it. NOTION_TODOS_DB_ID is printed by
# `eclipse notion-setup --parent <page-id>`.
NOTION_ACCESS_TOKEN=
NOTION_TODOS_DB_ID=

# --- HuggingFace (Phase 4): required to download the pyannote diarization model ---
# Only needed if you set diarize = true in eclipse.toml. Accept the model terms
# at https://hf.co/pyannote/speaker-diarization-3.1 first.
HF_TOKEN=
